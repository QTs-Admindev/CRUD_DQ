{
  "name": "AssetManagerService",
  "version": "1.0.0",
  "description": "Unified Lambda monorepo for asset management: vehicles, tires, sensors, tboxes, trackers",
  "scripts": {
    "build": "tsc --noEmit",
    "deploy:dev": "sls deploy --stage dev",
    "deploy:prod": "sls deploy --stage prod",
    "invoke:dev": "sls invoke local --stage dev -f",
    "package:dev": "sls package --stage dev",
    "package:prod": "sls package --stage prod"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-eventbridge": "^3.600.0",
    "axios": "^1.7.0",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
